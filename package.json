{
	"name": "@goobits/site-primitives",
	"version": "0.1.0",
	"description": "Reusable website primitives for sitemaps, humans.txt, changelogs, and public site metadata",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"test": "pnpm -r --if-present test",
		"typecheck": "pnpm -r --if-present typecheck",
		"clean": "pnpm -r --if-present clean"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@10.25.0"
}
