{
	"name": "@goobits/site-primitives",
	"version": "0.1.0",
	"description": "Reusable website primitives for sitemaps, humans.txt, changelogs, and public site metadata",
	"private": true,
	"type": "module",
	"scripts": {
		"test": "pnpm -r --if-present test",
		"typecheck": "pnpm -r --if-present typecheck",
		"clean": "pnpm -r --if-present clean",
		"api:scan": "pnpm --dir ../../.. codeatlas scan packages/@goobits/site-primitives --format json --out packages/@goobits/site-primitives/.codeatlas",
		"api:audit": "pnpm --dir ../../.. codeatlas audit packages/@goobits/site-primitives",
		"api:map": "pnpm --dir ../../.. codeatlas map packages/@goobits/site-primitives --out packages/@goobits/site-primitives/.codeatlas/atlas.mmd"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@11.10.0"
}
