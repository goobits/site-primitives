{
	"name": "@goobits/site-primitives",
	"version": "0.1.0",
	"description": "Reusable website primitives for sitemaps, humans.txt, changelogs, and public site metadata",
	"private": true,
	"type": "module",
	"scripts": {
		"test": "pnpm -r --if-present test",
		"typecheck": "pnpm -r --if-present typecheck",
		"clean": "pnpm -r --if-present clean",
		"api:codeatlas": "npx --yes @goobits/codeatlas@0.3.1",
		"api:scan": "pnpm run api:codeatlas -- scan . --format json --out .codeatlas",
		"api:audit": "pnpm run api:codeatlas -- audit .",
		"api:map": "pnpm run api:codeatlas -- map . --out .codeatlas/atlas.mmd"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@11.10.0"
}
