{
	"compilerOptions": {
		"allowJs": true,
		"allowImportingTsExtensions": true,
		"checkJs": true,
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"noEmit": true,
		"strict": true,
		"target": "ES2022",
		"types": [
			"svelte"
		]
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.d.ts",
		"tests/**/*.ts"
	]
}
