{
	"name": "@goobits/sitemap",
	"version": "0.2.0",
	"description": "Reusable sitemap core, server helpers, and ops layer (search-engine pings + URL HEAD validation) for SvelteKit and any modern Fetch-API runtime",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"sideEffects": false,
	"exports": {
		".": "./src/index.ts",
		"./core": "./src/core.ts",
		"./server": "./src/server.ts",
		"./ops": "./src/ops.ts",
		"./sveltekit": "./src/sveltekit.ts",
		"./ui": "./src/ui.ts",
		"./ui/SitemapPage.svelte": "./src/ui/SitemapPage.svelte"
	},
	"keywords": [
		"sitemap",
		"sitemap.xml",
		"sveltekit",
		"svelte",
		"svelte-5",
		"seo",
		"search-engine",
		"indexnow",
		"xml",
		"esm"
	],
	"author": "Goobits",
	"license": "MIT",
	"homepage": "https://github.com/goobits/site-primitives/tree/main/packages/sitemap#readme",
	"bugs": "https://github.com/goobits/site-primitives/issues",
	"repository": {
		"type": "git",
		"url": "https://github.com/goobits/site-primitives.git",
		"directory": "packages/sitemap"
	},
	"engines": {
		"node": ">=22"
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.0.0",
		"svelte": "^5.0.0",
		"typescript": "^5.0.0"
	},
	"peerDependenciesMeta": {
		"@sveltejs/kit": {
			"optional": true
		},
		"svelte": {
			"optional": true
		},
		"typescript": {
			"optional": true
		}
	},
	"devDependencies": {
		"@sveltejs/kit": "^2.69.1",
		"@types/node": "^26.1.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.10"
	},
	"scripts": {
		"typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json && svelte-check --workspace src/ui --fail-on-warnings",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"clean": "rm -rf node_modules .turbo"
	}
}
